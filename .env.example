# === Telegram (optional — needed for telegram-bot) ===
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=123456789

# === Slack (optional — needed for slack-bot) ===
# Bot User OAuth Token from Slack App settings
SLACK_BOT_TOKEN=xoxb-your-token-here
# App-Level Token with connections:write scope (for Socket Mode)
SLACK_APP_TOKEN=xapp-your-token-here
# Your Slack User ID (profile → ... → Copy member ID)
SLACK_USER_ID=U0XXXXXXX

# === Shared ===
# CDP port (default 9229)
CDP_PORT=9229
